{
  "permissions": {
    "allow": [
      "WebFetch(*)",
      "WebSearch"
    ],
    "deny": [
      "Bash(*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Read|Write|Edit|MultiEdit|Glob|Grep",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/.claude/hooks/whitelist.py\""
          }
        ]
      }
    ]
  }
}
